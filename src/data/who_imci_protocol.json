      "treatment": "즉시 이송 + 신생아 패혈증 가능성 고려",
      "referral": "immediate"
    },
    "eye_infection": {
      "icd10": "H10.9",
      "classification": {
        "gonococcal_ophthalmia": {
          "criteria": [
            "생후 4일 이내",
            "심한 화농성 분비물",
            "눈꺼풀 부종"
          ],
          "treatment": "카나마이신 25mg/kg IM (단회) + 즉시 이송",
          "referral": "immediate"
        },
        "bacterial_conjunctivitis": {
          "treatment": "테트라사이클린 안연고 × 5일"
        }
      }
    },
    "skin_infection": {
      "impetigo": {
        "icd10": "L01",
        "localized": {
          "treatment": "젠타마이신 또는 무피로신 연고 × 5일"
        },
        "extensive": {
          "treatment": "아목시실린 경구 + 이송 고려",
          "referral": "within_24h"
        }
      },
      "scabies": {
        "icd10": "B86",
        "treatment": "퍼메트린 5% 크림 (8시간 후 세척) 또는 벤질 벤조에이트"
