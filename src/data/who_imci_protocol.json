      "icd10": "P36.9",
      "danger_signs": [
        "수유 불가",
        "경련",
        "체온 < 35.5°C 또는 > 37.5°C",
        "빠른 호흡 ≥60회/분",
        "심한 함몰 배꼽",
        "피부 농포 또는 물집"
