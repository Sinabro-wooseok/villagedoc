  "conditions": {
    "malaria": {
      "icd10": "B54",
      "classification": {
        "severe": {
          "criteria": [
            "의식 저하 또는 경련",
            "심한 빈혈 (결막 창백)",
            "황달",
            "호흡 곤란",
            "소변량 감소",
            "반복 구토 (모든 음식/음료 거부)"
          ],
          "treatment": "즉시 이송 + 정맥 아르테수네이트",
          "referral": "immediate"
        },
        "uncomplicated": {
          "criteria": [
            "발열 > 37.5°C",
            "두통",
            "근육통",
            "오한",
            "RDT 양성"
          ],
          "treatment": {
            "first_line": "AL (아르테메터-루메판트린)",
            "dosing": {
              "weight_5_14kg": "AL 20/120mg 1정 × 2회/일 × 3일",
              "weight_15_24kg": "AL 20/120mg 2정 × 2회/일 × 3일",
              "weight_25_34kg": "AL 20/120mg 3정 × 2회/일 × 3일",
              "weight_over35kg": "AL 20/120mg 4정 × 2회/일 × 3일"
            },
            "notes": "지방 함유 음식과 복용 권장"
          },
          "referral": "within_24h_if_no_improvement"
        }
      },
      "danger_signs": [
        "경련",
        "의식 불명",
        "반복 구토",
        "심한 탈수",
        "황달 (간 침범)",
        "호흡 곤란 (뇌 말라리아)"
      ]
    },
    "pneumonia": {
      "icd10": "J18.9",
      "classification": {
        "severe": {
          "criteria": [
            "흉부 함몰(chest indrawing)",
            "코 벌렁임",
            "SpO2 < 90%",
            "청색증"
          ],
          "treatment": "즉시 이송",
          "referral": "immediate"
        },
        "non_severe": {
          "criteria": [
            "빠른 호흡: 2개월 미만 ≥60회/분, 2-11개월 ≥50회/분, 1-5세 ≥40회/분",
            "발열",
            "기침"
          ],
          "treatment": {
            "first_line": "아목시실린 40mg/kg/일 ÷ 2회 × 5일",
            "alternative": "코트리목사졸"
          }
        }
      },
      "who_breathing_rates": {
        "age_under_2mo": "≥60회/분",
        "age_2_11mo": "≥50회/분",
        "age_1_5yr": "≥40회/분"
      }
    },
    "diarrhea": {
      "icd10": "A09",
      "classification": {
        "severe_dehydration": {
          "criteria": [
            "무기력 또는 의식 저하",
            "함몰된 눈",
            "음수 불가",
            "피부 탄력 매우 저하 (>2초)"
