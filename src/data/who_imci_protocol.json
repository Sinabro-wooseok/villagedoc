            "갈증",
            "피부 탄력 저하 (1-2초)"
          ],
          "treatment": "ORS 75ml/kg × 4시간"
        },
        "no_dehydration": {
          "treatment": "ORS 10ml/kg/회 설사 후 + 아연 10-20mg/일 × 10-14일"
        }
      }
    },
    "acute_malnutrition": {
      "icd10": "E43",
      "classification": {
        "sam": {
          "name": "중증 급성 영양실조 (SAM)",
          "criteria": [
            "MUAC < 11.5cm (6-59개월)",
            "양쪽 부종",
            "WFH < -3 Z-score"
          ],
          "treatment": "RUTF (Ready-to-Use Therapeutic Food) + 즉시 이송",
          "referral": "within_6h"
        },
        "mam": {
          "name": "중등도 급성 영양실조 (MAM)",
          "criteria": [
            "MUAC 11.5-12.5cm",
            "WFH -3 to -2 Z-score"
          ],
          "treatment": "RUSF + 식이 상담"
        }
      }
    },
